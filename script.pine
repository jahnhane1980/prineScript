//@version=5
indicator("Cycle Intelligence - Dual-Cycle UI V35.0", overlay=true, max_boxes_count=500, max_labels_count=500)

// --- 1. SETTINGS ---
asset_type = input.string("A", "Asset Kategorie", options=["A", "B", "C", "D", "E", "F"])
manual_underlying = input.symbol("TVC:SILVER", "Vergleichs-Asset")

// --- 2. ENGINE & SCALING ---
s_per_bar = timeframe.in_seconds()
tf_scale  = 86400 / s_per_bar
int p_len_d = math.max(2, math.round(10 * tf_scale))
int p_len_w = math.max(3, math.round(30 * tf_scale))

var int last_low_idx = 0
int base_len = asset_type == "F" ? 42 : asset_type == "C" ? 40 : asset_type == "D" ? 32 : 35
var int dynamic_len = math.round(base_len * tf_scale)

var box[] d_boxes = array.new_box()
var box[] w_boxes = array.new_box()

// --- 3. DAILY ENGINE (CYCLES & DIAMONDS) ---
p_low = ta.pivotlow(low, p_len_d, p_len_d)

if not na(p_low)
    int current_low_idx = bar_index - p_len_d
    
    if last_low_idx != 0
        // Den höchsten Punkt zwischen dem letzten und dem aktuellen Tief finden
        float max_h = -1.0
        int peak_bar = last_low_idx
        for i = (bar_index - current_low_idx) to (bar_index - last_low_idx)
            if high[i] > max_h
                max_h := high[i]
                peak_bar := bar_index - i
        
        // Prozentuale Position berechnen
        float peak_pos_pct = (peak_bar - last_low_idx) / dynamic_len
        
        // Farbe bestimmen
        color p_col = peak_pos_pct < 0.5 ? color.fuchsia : peak_pos_pct > 1.8 ? color.red : peak_pos_pct > 1.4 ? color.orange : color.aqua
        
        // DIAMANT & PROZENT ZEICHNEN
        string p_txt = "◆\n" + str.tostring(peak_pos_pct * 100, "#") + "%"
        label.new(peak_bar, max_h + (ta.atr(14) * 0.5), text=p_txt, color=color.new(color.white, 100), textcolor=p_col, style=label.style_none, size=size.normal)
        
        // DAILY DREIECK (D)
        float tri_pos_pct = (peak_bar - last_low_idx) / dynamic_len
        color tri_col = tri_pos_pct < 0.5 ? color.orange : color.blue
        label.new(current_low_idx, low[p_len_d] - nz(ta.atr(14)[p_len_d]) * 0.8, text="D", style=label.style_triangleup, color=tri_col, textcolor=color.white, size=size.tiny)
        
        // PROGNOSE BOX
        box b_d = box.new(last_low_idx + math.round(dynamic_len * 0.85), high * 1.02, last_low_idx + math.round(dynamic_len * 1.15), low * 0.98, bgcolor=color.new(color.white, 50), border_style=line.style_dotted)
        array.push(d_boxes, b_d)
        if array.size(d_boxes) > 3
            box.delete(array.shift(d_boxes))
            
    last_low_idx := current_low_idx

// --- 4. WEEKLY ENGINE ---
var int last_low_idx_wk = 0
p_low_wk = ta.pivotlow(low, p_len_w, p_len_w)
int dynamic_len_wk = dynamic_len * 3

if not na(p_low_wk)
    int actual_pivot_bar = bar_index - p_len_w
    
    if last_low_idx_wk != 0
        // Peak für Weekly bestimmen (für Dreiecksfarbe)
        float max_h_wk = -1.0
        int peak_bar_wk = last_low_idx_wk
        for i = (bar_index - actual_pivot_bar) to (bar_index - last_low_idx_wk)
            if high[i] > max_h_wk
                max_h_wk := high[i]
                peak_bar_wk := bar_index - i
        
        float finished_peak_pct_wk = (peak_bar_wk - last_low_idx_wk) / dynamic_len_wk
        color tri_col_wk = finished_peak_pct_wk < 0.5 ? color.red : color.green
        
        // WEEKLY DREIECK (W)
        label.new(actual_pivot_bar, low[p_len_w] - nz(ta.atr(14)[p_len_w]) * 4.5, text="W", style=label.style_triangleup, color=tri_col_wk, textcolor=color.white, size=size.small)
        
        // WEEKLY PROGNOSE BOX
        box b_w = box.new(last_low_idx_wk + math.round(dynamic_len_wk * 0.85), high * 1.05, last_low_idx_wk + math.round(dynamic_len_wk * 1.15), low * 0.95, bgcolor=color.new(color.blue, 50), border_style=line.style_dashed)
        array.push(w_boxes, b_w)
        if array.size(w_boxes) > 3
            box.delete(array.shift(w_boxes))
            
    last_low_idx_wk := actual_pivot_bar

// --- 5. DASHBOARD ---
var table db = table.new(position.top_right, 1, 1, border_width=1)
if barstate.islast
    // Berechnung für den laufenden Zyklus (Live)
    float live_bars = bar_index - last_low_idx
    float live_peak_pct = live_bars / dynamic_len
    msg = "!!! ORACLE !!!\n" + "Status: Aktiv\n" + "Live Peak Pos: " + str.tostring(live_peak_pct * 100, "#") + "%"
    table.cell(db, 0, 0, msg, bgcolor=color.silver, text_color=color.black, text_size=size.small)
