//@version=5
indicator("AI Script: Macro-Handshake V52.0 (Clean Dots)", overlay=true)

// ==========================================
// SCHRITT 1: INPUTS
// ==========================================
sma20_len  = input.int(20, "SMA 20 (Rettung)", minval=5)
sma50_len  = input.int(50, "SMA 50 (Decke)", minval=10)
sma200_len = input.int(200, "SMA 200 (Anker)", minval=100)
atr_mult   = input.float(2.0, "ATR Puffer (Boden)", step=0.1)

// Schwellenwerte
dev_buy    = input.float(-30.0, "Kauf-Zone (Abstand %)", step=5.0)
dev_sell   = input.float(50.0, "Gier-Zone (Abstand %)", step=5.0)
vol_mult   = input.float(2.0, "Volumen-Climax Multiplikator", step=0.1)

// ==========================================
// SCHRITT 2: MTF-LOGIK (Daily Data)
// ==========================================
[d_close, d_high, d_low, d_sma20, d_sma50H, d_sma50L, d_sma200, d_atr, d_vol_avg] = request.security(syminfo.tickerid, "1D", [close, high, low, ta.sma(close, sma20_len), ta.sma(high, sma50_len), ta.sma(low, sma50_len), ta.sma(close, sma200_len), ta.atr(14), ta.sma(volume, 20)])

// ==========================================
// SCHRITT 3: LOGIK-BERECHNUNGEN
// ==========================================
decke  = d_sma50H
boden  = d_sma50L - (d_atr * atr_mult)
anker  = d_sma200
rescue = d_sma20

deviation = ((close - anker) / anker) * 100

// 1. BLAU: Akkumulation (Absorption am Boden)
is_buy_climax = (deviation <= dev_buy) and (volume > d_vol_avg * vol_mult) and (close > low + (high - low) * 0.4)

// 2. ROT: Distribution (Blow-off am Top)
is_sell_climax = (deviation >= dev_sell) and (volume > d_vol_avg * vol_mult) and (close < high - (high - low) * 0.4)

// 3. ORANGE: Notbremse (SMA 20 Bruch in Gier-Zone)
is_rescue_exit = (deviation >= dev_sell * 0.6) and (close < rescue)

// ==========================================
// SCHRITT 4: VISUALISIERUNG (Dezente Punkte)
// ==========================================

// --- SIGNALE UNTER DEM CHART ---
// Blau = Akkumulation
plotshape(is_buy_climax, "Akkumulation (Buy)", style=shape.circle, location=location.belowbar, color=color.new(#0000FF, 0), size=size.tiny, offset=0)

// Rot = Distribution
plotshape(is_sell_climax, "Distribution (Sell)", style=shape.circle, location=location.belowbar, color=color.new(#FF0000, 0), size=size.tiny, offset=1)

// Orange = Notbremse
plotshape(is_rescue_exit, "Rettung (SMA 20)", style=shape.circle, location=location.belowbar, color=color.new(#FF4500, 0), size=size.tiny, offset=2)


// --- BESTEHENDE SMA & KORRIDOR LOGIK ---
p_high = plot(decke, "Daily SMA 50 Decke", color=color.new(#FFA500, 30))
p_low  = plot(boden, "Daily SMA 50 Boden", color=color.new(#FF4500, 10), linewidth=2)
fill(p_high, p_low, color=(close > boden ? color.new(#00FF00, 92) : color.new(#FFA500, 94)), title="Corridor Fill")

plot(anker, "Daily SMA 200 Anker", color=color.new(#808080, 50), linewidth=3)
plot(rescue, "SMA 20 Notbremse", color=color.new(#FF4500, 40), linewidth=1, style=plot.style_linebr)

// Label für aktuelle Abweichung (rechts am Rand)
if barstate.islast
    label.new(bar_index, anker, "Dist: " + str.tostring(deviation, "#.#") + "%", style=label.style_label_left, color=color.new(color.gray, 50), textcolor=color.white, size=size.small)
